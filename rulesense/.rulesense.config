# rulesense configuration
# Override load_prob and severity per file for corpus quality scoring.
#
# load_prob: probability a glob-scoped file loads in a given session (0.0-1.0)
#   Default: 1.0 for always-loaded files, 0.5 for glob-scoped files
#   Adjust based on how often you edit files matching each glob pattern.
#
# severity: consequence weight for a file's rules (0.0-1.0+)
#   Default: 1.0
#   Higher values mean rule violations in this file have more impact on corpus score.

# load_prob:
#   ".claude/rules/api-design.md": 0.8    # we edit API files most sessions
#   ".claude/rules/legacy.md": 0.1        # legacy code is rarely touched
#   ".claude/rules/testing.md": 0.7       # tests are frequent

# severity:
#   ".claude/rules/security.md": 1.5      # security violations are high-consequence
#   ".claude/rules/style.md": 0.5         # style violations are low-consequence
